# API Environment Variables
# Copy to .env and fill in values before running locally.

# Runtime environment
NODE_ENV=development

# Server
PORT=3001

# Logging
LOG_LEVEL=info

# Database
DATABASE_URL=postgresql://simplifi:simplifi_local@localhost:5432/simplifi_dev

# Cache
REDIS_URL=redis://localhost:6379

# Auth — generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=change-me-to-a-32-char-minimum-random-secret

# AWS / KMS (optional — required for encryption layer)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# KMS_KEY_ID=
