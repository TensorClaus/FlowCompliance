{
  "name": "simplifi",
  "private": true,
  "type": "module",
  "version": "0.0.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm -r --parallel dev",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "pnpm -r typecheck",
    "type-check": "pnpm -r typecheck",
    "test": "vitest run --passWithNoTests",
    "test:e2e": "pnpm --filter @simplifi/web exec playwright test",
    "prepare": "husky",
    "postinstall": "pnpm --filter @simplifi/api exec prisma generate"
  },
  "devDependencies": {
    "@eslint/js": "^9.12.0",
    "@vitest/coverage-istanbul": "^2.1.9",
    "@vitest/coverage-v8": "^2.0.0",
    "eslint": "^9.12.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import-x": "^4.4.0",
    "eslint-plugin-unicorn": "^56.0.0",
    "globals": "^15.11.0",
    "husky": "^9.1.0",
    "lint-staged": "^15.2.0",
    "prettier": "^3.3.0",
    "typescript": "^5.4.0",
    "typescript-eslint": "^8.8.0",
    "vitest": "^2.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/engines",
      "prisma",
      "@swc/core"
    ],
    "overrides": {
      "esbuild@<=0.24.2": ">=0.25.0",
      "brace-expansion@<1.1.13": "2.0.2",
      "brace-expansion@>=4.0.0 <5.0.5": ">=5.0.5",
      "defu@<=6.1.4": ">=6.1.5",
      "vite@<=6.4.1": "^6.4.2",
      "hono@<4.12.12": ">=4.12.12",
      "hono@>=4.0.0 <=4.12.11": ">=4.12.12",
      "@hono/node-server@<1.19.13": ">=1.19.13",
      "hono@<4.12.14": ">=4.12.14",
      "postcss@<8.5.10": ">=8.5.10",
      "hono@<4.12.16": ">=4.12.16",
      "fast-xml-builder@<=1.1.6": ">=1.1.7",
      "fast-uri@<=3.1.0": ">=3.1.1",
      "fast-uri@<=3.1.1": ">=3.1.2",
      "fast-xml-parser@<5.7.0": ">=5.7.0",
      "hono@<4.12.18": ">=4.12.18",
      "kysely@>=0.26.0 <0.28.17": ">=0.28.17"
    }
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,yaml,yml,md,html,css}": [
      "prettier --write"
    ]
  }
}
